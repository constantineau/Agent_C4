# Onboard race console (Pi) — serves the SAME iPad app as the cloud web, but pointed ONLY at
# the onboard engine over boat-local Wi-Fi. No cloud, no auth, no /ws chat. Listens on :8091
# (host networking; avoids :80 conflicts on the shared bench VM and is fine on the boat).
#
# nginx template: ${COPILOT_UPSTREAM} is substituted at container start (stock nginx envsubst).
# On the boat the copilot runs on the ORIN, reached over the DIRECT Pi↔Orin ethernet
# (default http://10.10.10.2:8300/ — no Wi-Fi/WAN dependency); the bench overlay overrides to
# the Orin's Tailscale IP. The engine is on this host (:8200).
server {
    listen 8091;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    # gzip text assets (dashboard.js is ~89 KB raw / ~27 KB gzipped — kinder to boat Wi-Fi)
    gzip on;
    gzip_comp_level 5;
    gzip_min_length 1024;
    gzip_types text/css application/javascript application/json image/svg+xml;
    gzip_vary on;

    # Flip the app into onboard mode by overriding the static config.js (which ships ONBOARD=false).
    location = /config.js {
        default_type application/javascript;
        add_header Cache-Control "no-store";
        return 200 "window.SR33_ONBOARD = true;";
    }

    location / {
        try_files $uri $uri/ /index.html;
        # no-cache (NOT no-store): the browser may keep a copy but must revalidate every load,
        # so a deploy shows up on the next reload — no stale dashboards mid-race-week. Assets
        # are small + gzipped + boat-local; revalidation cost is a 304 on the LAN.
        add_header Cache-Control "no-cache";
    }

    # REST → the onboard engine (host-networked on :8200). No /ws location: the engine has no
    # LLM chat (deterministic only), and the app skips the WebSocket in onboard mode.
    location /api/ {
        proxy_pass http://127.0.0.1:8200/;
        proxy_set_header Host $host;
    }

    # Tier-2 onboard LLM copilot (writes the dashboard commentary). Separate box (Orin) on the
    # boat-local network. The dashboard POSTs its tile snapshot; the brief is best-effort — if the
    # copilot is down the dashboard falls back to the engine-read commentary.
    location /copilot/ {
        proxy_pass ${COPILOT_UPSTREAM};
        proxy_set_header Host $host;
        proxy_read_timeout 130s;   # the 7B is slow (~45 s warm, ~2 min cold)
        proxy_buffering off;       # stream the tile deep-dive (/detail) token-by-token
    }
}
