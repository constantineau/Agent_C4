# Copy to .env and fill in. .env is gitignored.

# --- TimescaleDB ---
POSTGRES_USER=sr33
POSTGRES_PASSWORD=sr33-dev
POSTGRES_DB=sr33_dev
# DSN used by the services (host is the compose service name "timescaledb")
DATABASE_URL=postgresql://sr33:sr33-dev@timescaledb:5432/sr33_dev

# --- Ingestion auth ---
# Bearer token the Pi uplink uses to POST telemetry batches.
INGEST_TOKEN=dev-ingest-token

# --- Agent ---
# Anthropic API key for the agent's tool-use loop (Phase 4). Leave blank in Phase 0:
# the agent falls back to a deterministic, tool-grounded reply with no LLM call.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Playbook synthesis + routing briefing try these in order (Fable primary, Opus fallback):
ANTHROPIC_MODEL_CHAIN=claude-fable-5,claude-opus-4-8

# --- Web app auth (Phase 7) ---
# Single shared boat password for the crew web interface (POST /auth exchanges it for a
# signed bearer token used on REST + the WebSocket). USE A REAL SECRET IN PROD.
BOAT_PASSWORD=sr33-dev
# HMAC secret that signs session tokens. Defaults to a value derived from BOAT_PASSWORD;
# set a fresh random value in prod (e.g. `openssl rand -hex 32`).
AUTH_SECRET=
# Session lifetime in hours (default 720 = 30 days, so the crew don't re-auth mid-passage).
AUTH_TTL_HOURS=720
# Set false to disable the check entirely (open bench only — never in prod).
AUTH_ENABLED=true

# --- TLS / domain (Phase 7, prod only) ---
# Public domain for the crew web app (the TLS cert CN). DNS A record must point at the VPS.
SERVER_NAME=nav.example.com
# Email for the Let's Encrypt account (expiry notices). Used by deploy/init_tls.sh.
CERTBOT_EMAIL=you@example.com
# Web nginx serves HTTPS once a cert exists; leave true for prod. (Dev web ignores this.)
TLS_ENABLED=true

# --- Boat identity ---
BOAT_ID=sr33

# --- C4 Performance Lab (dev compose service `lab`, :8103) ---
# Shared team login for the Lab browser app (compose default: lab-dev; the standing
# lab.racertracer.net container uses its own value).
LAB_PASSWORD=lab-dev
# Set false to disable the Lab gate (open bench only).
LAB_AUTH_ENABLED=true
# Optional: separate HMAC secret + TTL for Lab session tokens (default derived from LAB_PASSWORD).
LAB_AUTH_SECRET=
LAB_AUTH_TTL_HOURS=720
# Feedback widget -> GitHub issues (💬 button on the Lab + crew dashboard).
GITHUB_TOKEN=
GITHUB_REPO=constantineau/Agent_C4
FEEDBACK_ALLOW_ORIGINS=https://c4.racertracer.net,https://lab.racertracer.net,http://localhost:8091
# Obstacle sources: COASTLINE_SOURCE=enc|global, COASTLINE_GLOBAL=gshhg|natural_earth, GSHHG_RES=f..c
#COASTLINE_SOURCE=enc
# Race mode default for the cloud gate (dev compose sets practice; prod omits -> fail-closed race).
#RACE_MODE_DEFAULT=practice

# --- Lab "Lock-in & Deploy" push-to-boat (vps/lab/app/deploy.py; all optional) ---
# SSH targets the Lab uses to push a frozen playbook to the boat. Unset -> the Lab offers
# download-only and the bundle is carried over by hand (scp / the engine's /playbook/load).
#DEPLOY_ORIN_HOST=agent-c4@100.70.110.72
#DEPLOY_ORIN_PLAYBOOK_PATH=/home/agent-c4/playbooks/current.json
#DEPLOY_ORIN_SERVICE=sr33-orin-copilot
#DEPLOY_PI_HOST=sr33-pi@100.79.180.102
#DEPLOY_PI_ENGINE=http://127.0.0.1:8200

# --- Onboard copilot extras (Orin service env, documented here for reference) ---
# Engine address failover order (boat-local first, Tailscale fallback):
#ENGINE_URL_FALLBACK=http://100.79.180.102:8200
# Label stamped into signed playbooks at freeze:
#PLAYBOOK_SIGNED_BY=
