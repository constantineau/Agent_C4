server {
    listen 80;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    # gzip text assets (no-build vanilla JS — compression is the transfer lever over Starlink)
    gzip on;
    gzip_comp_level 5;
    gzip_min_length 1024;
    gzip_types text/css application/javascript application/json image/svg+xml;
    gzip_vary on;

    # ACME http-01 challenge for Let's Encrypt issuance/renewal (prod; harmless 404 in dev).
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    # WebSocket chat to the agent service.
    location /ws {
        proxy_pass http://${AGENT_HOST}:${AGENT_PORT}/ws;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 3600s;
    }

    # REST mirrors (live instrument strip, health).
    location /api/ {
        proxy_pass http://${AGENT_HOST}:${AGENT_PORT}/;
        proxy_set_header Host $host;
    }
}
